{
  "name": "wess",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "vite --strictPort",
    "server": "node server.js",
    "dev": "node server.js & vite --strictPort",
    "build": "vite build",
    "serve": "npm run build && node server.js",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test": "npm run test:unit && npm run test:browser",
    "test:unit": "vitest run",
    "test:browser": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
